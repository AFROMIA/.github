# AFROMIA — Profil LOCAL (apps sur la machine + infra Docker)
# Usage: scripts/setup-env.ps1 local  |  make env-local
# Lancer: scripts/dev.ps1 local      |  make dev-local
#
# Démarre Postgres, Redis et MinIO dans Docker.
# Backend (uvicorn) et Frontend (Next.js) tournent en local.

AFROMIA_ENV=local
ENVIRONMENT=development
DEBUG_ENABLED=true

# --- Base de données (Postgres Docker exposé sur localhost) ---
DATABASE_URL=postgresql+asyncpg://afromia:afromia@localhost:5432/afromia
DATABASE_URL_SYNC=postgresql+psycopg://afromia:afromia@localhost:5432/afromia
DATABASE_SSL=false
DATABASE_SKIP_EXTENSIONS=false

# --- Redis / Celery (Docker exposé sur localhost) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
SECRET_KEY=change-me

# --- Services ---
AFFINIORA_API_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AFFINIORA_URL=http://localhost:8001
NEXT_PUBLIC_DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- S3 / MinIO (Docker exposé sur localhost) ---
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-west-1
S3_BUCKET_NAME=afromia-media-dev

# --- Stripe (dev) ---
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- AFFINIORA AI Engine ---
MODEL_CACHE_DIR=./models/cache
REDIS_URL_AFFINIORA=redis://localhost:6380/3
