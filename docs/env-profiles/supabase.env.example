# AFROMIA — Profil SUPABASE (apps locales + base PostgreSQL Supabase)
# Usage: scripts/setup-env.ps1 supabase  |  make env-supabase
# Lancer: scripts/dev.ps1 supabase      |  make dev-supabase
#
# 1. Créer un projet sur https://supabase.com
# 2. Activer les extensions : postgis, vector (Dashboard > Database > Extensions)
# 3. Remplacer [PROJECT_REF], [PASSWORD], [REGION] ci-dessous
# 4. Redis et MinIO restent en Docker local (Supabase ne les fournit pas)

AFROMIA_ENV=supabase
ENVIRONMENT=development
DEBUG_ENABLED=true

# --- Supabase — Session pooler (port 5432) : dev local + Alembic migrations ---
# Project Settings > Database > Connection string > URI (mode Session)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Alternative — connexion directe (migrations lourdes) :
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
# DATABASE_URL_SYNC=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

DATABASE_SSL=true
DATABASE_SKIP_EXTENSIONS=false

# --- Redis / MinIO locaux (Docker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
SECRET_KEY=change-me

# --- Services ---
AFFINIORA_API_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AFFINIORA_URL=http://localhost:8001
NEXT_PUBLIC_DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- S3 — en dev local MinIO ; en prod Supabase Storage ou S3 ---
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-west-1
S3_BUCKET_NAME=afromia-media-dev

# --- Stripe (dev) ---
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- AFFINIORA ---
MODEL_CACHE_DIR=./models/cache
REDIS_URL_AFFINIORA=redis://localhost:6380/3
