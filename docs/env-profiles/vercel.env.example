# AFROMIA — Variables Vercel (Frontend) + Supabase (Backend serverless)
# Référence pour déploiement — ne pas committer avec de vraies valeurs.
# Configurer dans Vercel Dashboard > Settings > Environment Variables

# --- Frontend (Vercel) ---
NEXT_PUBLIC_API_URL=https://api.votre-domaine.com
NEXT_PUBLIC_WS_URL=wss://api.votre-domaine.com
NEXT_PUBLIC_AFFINIORA_URL=https://affiniora.votre-domaine.com
NEXT_PUBLIC_DEBUG=false
ENVIRONMENT=production

# --- Backend (Railway / Fly.io / AWS — pas sur Vercel si WebSocket/Celery) ---
# Supabase Transaction pooler (port 6543) — recommandé serverless
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_SSL=true

# Upstash Redis (alternative à ElastiCache pour Vercel-adjacent stack)
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379

JWT_SECRET_KEY=
AFFINIORA_API_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase Storage (optionnel — remplace MinIO en prod)
# AWS_ACCESS_KEY_ID=  (Supabase S3-compatible keys)
# S3_ENDPOINT_URL=https://[PROJECT_REF].supabase.co/storage/v1/s3
