# AFROMIA — Profil DOCKER (stack complet dans Docker)
# Usage: scripts/setup-env.ps1 docker  |  make env-docker
# Lancer: scripts/dev.ps1 docker      |  make dev-docker

AFROMIA_ENV=docker
ENVIRONMENT=development
DEBUG_ENABLED=true

# --- Base de données (Postgres Docker — hostname interne pour les conteneurs) ---
# Les services backend/celery surchargent ces valeurs dans docker-compose.yml
DATABASE_URL=postgresql+asyncpg://afromia:afromia@postgres:5432/afromia
DATABASE_URL_SYNC=postgresql+psycopg://afromia:afromia@postgres:5432/afromia
DATABASE_SSL=false
DATABASE_SKIP_EXTENSIONS=false

# --- Redis / Celery (Docker) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
SECRET_KEY=change-me

# --- Services (URLs vues depuis le navigateur hôte) ---
AFFINIORA_API_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AFFINIORA_URL=http://localhost:8001
NEXT_PUBLIC_DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- S3 / MinIO (Docker) ---
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-west-1
S3_BUCKET_NAME=afromia-media-dev

# --- Stripe (dev) ---
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- AFFINIORA AI Engine ---
MODEL_CACHE_DIR=./models/cache
